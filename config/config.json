{
    "markets": {
        "_comment": "Enable/disable market monitoring. Set to true to monitor, false to skip.",
        "us": true,
        "china": true
    },
    "screeners": {
        "market": {
            "url": "https://www.tradingview.com/screener/fMf9cTi2/"
        },
