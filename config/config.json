            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
            "Accept-Language": "en-US,en;q=0.5"
        },
        "filters": {
            "_comment": "Screener filter thresholds — adjust to tune which stocks get alerted on",
            "min_change_percent": 6,
            "min_volume": 1000000,
            "max_price": 100,
            "min_price": 0.5,
            "min_relative_volume": 2,
            "large_cap_threshold": 10000000000,
            "large_cap_min_change_percent": 6,
            "small_cap_min_change_percent": 10,
            "min_market_cap_non_tech": 200000000
        }
    },
    "china_screeners": {
        "_comment": "A-share (Chinese stock market) screener configuration",
        "filters": {
            "_comment": "A-share filter thresholds — adjust to tune which stocks get alerted on",
            "china_min_change_percent": 5,
            "china_max_change_percent": 15,
            "china_min_volume": 1000000,
            "china_min_price": 2.0,
            "china_max_price": 500.0,
            "china_min_market_cap": 500000000,
            "china_min_volume_ratio": 1.5,
            "china_min_turnover": 3000000000
        }
    },
    "us_screeners": {
        "_comment": "US stock (美股) screener configuration — akshare/East Money, no API key needed",
        "filters": {
            "_comment": "US filter thresholds — catches big movers in BOTH directions (abs(涨跌幅) >= min)",
            "us_min_change_percent": 5.0,
            "us_max_change_percent": 30.0,
            "us_min_volume": 500000,
            "us_min_price": 3.0,
            "us_max_price": 2000.0,
            "us_min_market_cap": 300000000
        }
    },
    "email": {
        "send_email": false,
        "email_report": true,
        "contacts_sheet_url": "https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit",
        "google_sheets_api_key": "",
        "gmail_api_key": "",
        "credentials_path": "credentials.json",
        "token_path": "token.json"
    },
    "china_news": {
        "_comment": "China A-share news collector configuration",
        "back_hours": 48,
        "max_news_per_stock": 3
    },
    "enrichment": {
        "_comment": "A股增强层 — 第一批(板块/资金流/东财资讯)+ 第二批(龙虎榜/打板池/北向资金); 仅对异动A股调用, 失败不影响主预警",
        "enabled": true,
        "min_interval": 1.0,
        "news_limit": 3,
        "concept_limit": 8,
        "lhb": {"enabled": true, "_comment": "龙虎榜: akshare stock_lhb_detail_em, 盘后公布, 盘中回退最近交易日"},
        "zt_pool": {"enabled": true, "_comment": "打板池(涨停股池): akshare stock_zt_pool_em"},
        "northbound": {"enabled": true, "_comment": "北向资金: akshare stock_hsgt_fund_flow_summary_em; 盘中多为0(港交所2024-08起停盘中披露), 收盘回填"}
    },
    "news_collector": {
        "back_hours": 24,
        "summarize_articles": true,
        "browser_headers": {
            "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36",
            "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8",
